<div class="container-fluid text-center">
    <nav aria-label="breadcrumb">
        <ol class="breadcrumb">
            <li class="breadcrumb-item"><a href="/">INICIO</a></li>
            <li class="breadcrumb-item"><a href="/filamaquina">FILA</a></li>
            <li class="breadcrumb-item">MAQUINA ATUAL: <h3>
                    <%= maquinaAtual.descMaquina %> -> <%= maquinaAtual.setor.descSetor%>
                </h3>
            </li>
        </ol>
    </nav>
</div>
<main class="container-fluid">
    <% %>
        <form action="" method="post" id="form-fila">
            <input type="hidden" value="<%= idMaquina %>" id="idMaquina" />
            <table class="table table-hover">
                <thead class="table-dark">
                    <tr>
                        <td>#</td>
                        <td>OP</td>
                        <td>CLIENTE</td>
                        <td>PRODUTO</td>
                        <td>QTD PEDIDO</td>
                        <td>QTD PRODUZIDO</td>
                        <td>COMEÇA</td>
                        <td>TERMINA</td>
                        <td>opções</td>
                    </tr>
                </thead>
                <tbody id="tbody">
                    <% console.log(arrHistorico); var i=0; Object.keys(prevision).forEach(key=>{

                        %>
                        <tr class="linha">
                            <td style="display: none;" class="idFilaMaquina">
                                <%=prevision[key].idFilaMaquina%>
                            </td>
                            <td style="display: none;" class="idOrdemProducao">
                                <%=prevision[key].idOrdemProducao%>
                            </td>
                            <td class="ordem">
                                <%=i%>
                            </td>
                            <td>
                                <%= prevision[key].ordemProducao %>
                            </td>
                            <td>
                                <%= prevision[key].cliente %>
                                    

                            </td>
                            <td>
                                <div class="row">
                                   <%= prevision[key].produto %>  
                                </div>
                                <div class="row">
                                <p class="d-inline-flex gap-1">
                                        <a class="btn btn-outline-info" data-bs-toggle="collapse" href="#collapse<%= prevision[key].idOrdemProducao%>"
                                            role="button" aria-expanded="false" aria-controls="collapse<%= prevision[key].idOrdemProducao%>">
                                            HISTORICO APONTAMENTOS
                                        </a>
                                    </p>
                                    <% arrHistorico.forEach(historico=>{
                                        if(prevision[key].idOrdemProducao == historico.idOrdemProducao){%>

                                        <div class="collapse" id="collapse<%= prevision[key].idOrdemProducao%>">
                                            <div class="row">
                                                <div class="col-sm-4"><%=historico.data%></div>
                                                <div class="col-sm-4"><%=historico.operador%></div>
                                                <div class="col-sm-4"><%=historico.quantidade%></div>
                                            </div>
                                        </div>
                                        <% } }) %>

                                </div>

                                
                            </td>
                            <td class="text-center">
                                <%= prevision[key].orderQuantity %>
                            </td>
                            <td class="text-center">
                                <%= prevision[key].quantityProduced %>
                            </td>
                            <td>
                                <%= prevision[key].previsionStart.toLocaleString()=="" ? new
                                    Date().toLocaleString():prevision[key].previsionStart.toLocaleString() %>
                            </td>
                            <td>
                                <%= prevision[key].previsionEnd.toLocaleString() %>
                            </td>
                            <td><a href="" data-bs-toggle="modal" data-bs-target="#staticBackdropTransfer"
                                    onclick='transferir("<%=prevision[key].idFilaMaquina%>","<%=prevision[key].idMaquina%>")'><img
                                        src="/img/transfer-24.png"></a>
                                <a
                                    href="/filamaquina/delete/<%=prevision[key].idFilaMaquina%>/<%= prevision[key].idOrdemProducao %>/<%=prevision[key].idMaquina%>"><img
                                        src="/img/delete-24.png"></a>
                                <a
                                    href="/filamaquina/finalizar/<%=prevision[key].idFilaMaquina%>/<%=prevision[key].idMaquina%>/<%= prevision[key].idOrdemProducao %>"><img
                                        src="/img/check-24.png"></a>

                            </td>
                        </tr>

                        <% i++; })%>
                </tbody>
            </table>

            <input type="submit" class="btn btn-success" value="CALCULAR">
        </form>

</main>

<script>
    document.addEventListener('DOMContentLoaded', function () {
        new Sortable(document.querySelector('.table tbody'), {
            animation: 150,
            ghostClass: "ghost"
        })
    })
</script>